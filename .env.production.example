# Production environment variables for Vercel.
# Set these in the Vercel dashboard (Project > Settings > Environment Variables)
# or via `vercel env add`. They are injected at BUILD TIME for Vite.
#
# IMPORTANT: any var consumed by the frontend MUST be prefixed with VITE_.

# Absolute production URL — used for canonical links, sitemap, OG image, and
# JSON-LD absolute URLs. Set this to your real domain (no trailing slash).
VITE_SITE_URL=https://adzani-store.vercel.app

# Supabase project (public anon key is safe to expose; RLS is the real gate).
VITE_SUPABASE_URL=https://dkcwkxjujevluarvlarp.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# WhatsApp number that receives orders (E.164, no +, e.g. 6281234567890).
VITE_WHATSAPP_ADMIN=6281234567890

# Comma-separated admin emails allowed into /admin.
VITE_ADMIN_EMAILS=admin@example.com
