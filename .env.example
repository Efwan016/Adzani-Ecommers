# Copy to .env and fill with real values. Never commit .env.

# Public Supabase project URL + anon key (safe to expose, RLS enforced).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production site origin (used for canonical URLs, OG tags, sitemap links).
# Must match the real domain serving this app (e.g. https://adzani-store.vercel.app).
VITE_SITE_URL=https://adzani-store.vercel.app

# Admin WhatsApp number in international format (digits only, no +).
VITE_WHATSAPP_ADMIN=6281234567890

# Comma-separated admin emails allowed to open /admin.
VITE_ADMIN_EMAILS=admin@example.com

# Optional: privacy-friendly error/event monitor endpoint.
# Leave empty to disable monitoring entirely (no network calls, CSP-clean).
VITE_MONITOR_URL=
